<?xml version="1.0" encoding="utf-8"?>
<!-- H-04: Android 12+ のバックアップ/端末間転送で機密データを持ち出さない。
     クラウドバックアップも端末間転送も全体を除外する。 -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
