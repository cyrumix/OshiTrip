# =============================================================================
# 環境変数テンプレート（秘密情報は含めない）
# 使い方:
#   1) 本ファイルを .env.development / .env.staging / .env.production にコピー
#   2) 各値を実プロジェクトの値で埋める（これらのファイルは .gitignore 済み）
#   3) Flutter へは JSON 版(.env.<flavor>.json)を --dart-define-from-file で渡す
#      （下部の変換メモ参照）。CI ではシークレットから注入する。
#
# 重要: anon key は公開クライアント用の公開鍵。service_role キーは
#       絶対にアプリ／リポジトリに置かない（サーバー/Edge Functionのみ）。
# =============================================================================

# --- アプリ環境識別 ---
# 環境（flavor）は dart-define ではなく Dart entry（main_<flavor>.dart。
# --flavor <name> -t lib/main_<name>.dart）で決まる。APP_ENV/APP_NAME は
# ここに追加しない（真実の所在が二重になり、値が食い違っても検知できない
# ため, H-01）。Android/iOS ネイティブの applicationId/bundle id との不一致は
# core/config/flavor_guard.dart が起動時に検証する。アプリ表示名は
# AppEnv.appTitle（Dart側）と各プラットフォームの flavor 別リソース
# （Android: res/values-<flavor>/strings.xml, iOS: Flutter/<Flavor>.xcconfig
# の APP_DISPLAY_NAME）で分離する。

# --- Supabase（環境ごとに別プロジェクト: ADR-0007） ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# --- Firebase Cloud Messaging（Push: ADR-0009） ---
# 実ファイルはリポジトリに置かない（.gitignore 済み）:
#   android/app/google-services.json
#   ios/Runner/GoogleService-Info.plist
FCM_PROJECT_ID=your-firebase-project-id
FCM_SENDER_ID=your-sender-id

# --- 少人数表示保護の閾値（§10.3 / ADR-0005/0008、Phase 5で確定） ---
PERFORMANCE_HEADCOUNT_MIN_DISPLAY=10

# --- ログ/診断 ---
LOG_LEVEL=debug                     # production では info 以上を推奨
SENTRY_DSN=                         # 任意。未使用なら空

# =============================================================================
# JSON 変換メモ（--dart-define-from-file 用）:
#   .env.development.json 例:
#   {
#     "SUPABASE_URL": "https://xxxx.supabase.co",
#     "SUPABASE_ANON_KEY": "xxxx",
#     "PERFORMANCE_HEADCOUNT_MIN_DISPLAY": "10",
#     "LOG_LEVEL": "debug"
#   }
# =============================================================================
